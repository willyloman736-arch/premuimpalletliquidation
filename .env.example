# ----------------------------------------------------------------------------
# PLF - Palette Liquidation France — environment variables
# Copy this file to `.env.local` and fill in real values to enable the
# optional integrations. The site works out of the box WITHOUT any of these,
# using the bundled seed catalogue in src/data/palettes.ts.
# ----------------------------------------------------------------------------

# --- Supabase (live product catalogue + admin) ------------------------------
# When set, the catalogue is fetched from the Supabase `palettes` table.
# When empty, the bundled static seed data is used instead.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# --- Admin login (used by /admin) -------------------------------------------
NEXT_PUBLIC_ADMIN_USERNAME=admin
NEXT_PUBLIC_ADMIN_PASSWORD=changeme

# --- Cloudinary (admin image uploads) ---------------------------------------
NEXT_PUBLIC_CLOUDINARY_URL=
NEXT_PUBLIC_CLOUDINARY_UPLOAD_PRESET=

# --- EmailJS (order confirmation emails at checkout) ------------------------
NEXT_PUBLIC_EMAILJS_PUBLIC_KEY=
NEXT_PUBLIC_EMAILJS_SERVICE_ID=
NEXT_PUBLIC_EMAILJS_TEMPLATE_CLIENT=
NEXT_PUBLIC_EMAILJS_TEMPLATE_ADMIN=

# --- Stripe (card payments at checkout, disabled by default) ----------------
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
NEXT_PUBLIC_STRIPE_BACKEND_URL=
